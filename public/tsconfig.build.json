{
  "extends": "./tsconfig.check.json",
  "compilerOptions": {
    // project
    "rootDir": "src",

    // recommended
    "allowImportingTsExtensions": false,

    // emit
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true
  },
  "include": ["src"]
}
